{
	"name": "copa-frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"lint:fix": "eslint . --fix",
		"test:unit": "tsx --test \"tests/unit/**/*.test.ts\"",
		"test:contract": "node ./scripts/verify_audit_contract.mjs",
		"format": "pnpm run lint:fix && prettier --write .",
		"test:e2e": "playwright test tests/e2e",
		"test:e2e:ui": "playwright test tests/e2e --ui",
		"test:e2e:list": "playwright test tests/e2e --list",
		"test:visual": "E2E_BASE_URL=http://localhost:3000 playwright test --project=visual-chromium --workers=1",
		"test:visual:ui": "E2E_BASE_URL=http://localhost:3000 playwright test --project=visual-chromium --ui",
		"test:visual:list": "E2E_BASE_URL=http://localhost:3000 playwright test --project=visual-chromium --list",
		"test:visual:percy": "percy exec -- pnpm test:visual",
		"test:contracts:shared": "node ../testing/scripts/validate-contracts.mjs",
		"screenshots:web": "node scripts/capture-local-screenshots.mjs",
		"assets:index": "node ../copa-assets/scripts/build-asset-index.mjs",
		"assets:upload": "node ../copa-assets/scripts/upload-to-cloudinary.mjs"
	},
	"dependencies": {
		"@fontsource/opendyslexic": "^5.2.5",
		"@tanstack/react-form": "^1.32.0",
		"@tanstack/react-query": "^5.100.10",
		"@tanstack/react-table": "^8.21.3",
		"axios": "^1.16.1",
		"class-variance-authority": "^0.7.1",
		"cloudinary": "^2.10.0",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"jspdf": "^4.2.1",
		"jspdf-autotable": "^5.0.7",
		"jszip": "^3.10.1",
		"lucide-react": "^0.577.0",
		"microdiff": "^1.5.0",
		"next": "15.5.12",
		"next-cloudinary": "^6.17.5",
		"next-intl": "^4.12.0",
		"next-themes": "^0.4.6",
		"prettier": "^3.8.3",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"xlsx": "^0.18.5",
		"xlsx-js-style": "^1.2.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@browserbasehq/stagehand": "^3.4.0",
		"@eslint/eslintrc": "^3.3.5",
		"@percy/cli": "^1.31.13",
		"@percy/playwright": "^1.1.0",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@tsconfig/recommended": "^1.0.13",
		"@types/node": "^20.19.41",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.39.4",
		"eslint-config-next": "15.5.12",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"playwright": "^1.60.0",
		"shadcn": "^4.7.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3"
	}
}
